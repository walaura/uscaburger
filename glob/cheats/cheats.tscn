[sub_resource type="GDScript" id="GDScript_jmmtx"]
resource_name = "UiDevStoreDebug"
script/source = "extends FoldableContainer

var config := ConfigFile.new()

var _processed_once := false;

func _process(_delta: float) -> void:
	if _processed_once:
		return;
	_processed_once = true;
	var datums := CurrentRun_Inventory._get_all_items()
	for datum in datums:
		var btn := Button.new()
		btn.text = datum
		btn.pressed.connect(func() -> void:
			CurrentRun.inventory.hold_item(
				CurrentRun.inventory.get_item_at_purchasable_tier((
					CurrentRun_Inventory._get_item_raw(datum) 
				))
			)
		)
		($VBoxContainer as Container).add_child(btn)
		
	var err := config.load(\"user://debug.cfg\")
	if err:
		return
	var maybe_stored : Variant = config.get_value('debug','x', null)
	if maybe_stored is PackedByteArray:
		@warning_ignore(\"unsafe_cast\")
		var maybe_stored_d: Dictionary[String, int] = bytes_to_var(maybe_stored as PackedByteArray)
		for key: String in maybe_stored_d.keys():
			var item := CurrentRun_Inventory._get_item_raw(key)
			if(item != null):
				CurrentRun.inventory.hold_item(
					item.apply_tier(maybe_stored_d[key])
				)


func _on_save_button_pressed() -> void:
	config.set_value(\"debug\", \"x\", var_to_bytes(CurrentRun.inventory._held_items))
	config.save(\"user://debug.cfg\")


func _on_clear_button_pressed() -> void:
	config.clear()
	config.save(\"user://debug.cfg\")
"

[sub_resource type="GDScript" id="GDScript_todtk"]
script/source = "extends FoldableContainer


func _process(_delta: float) -> void:
	($VBoxContainer/Label as Label).text = JSON.stringify(CurrentRun.inventory._held_items, \"  \")
"

