[sub_resource type="GDScript" id="GDScript_dn3wt"]
resource_name = "UI_DevStoreDebug"
script/source = "extends FoldableContainer

var config := ConfigFile.new()

var _processed_once := false;

func _process(_delta: float) -> void:
	if _processed_once:
		return;
	_processed_once = true;
	var datums := CurrentRunState_Inventory.get_all_items()
	for datum in datums:
		var btn := Button.new()
		btn.text = datum
		btn.pressed.connect(func() -> void:
			CurrentRunState.inventory_handler.hold_item(datum)
		)
		($VBoxContainer as Container).add_child(btn)
		
	var err := config.load(\"user://debug.cfg\")
	if err:
		return
	var maybe_stored : Variant = config.get_value('debug','x', null)
	if maybe_stored is PackedByteArray:
		@warning_ignore(\"unsafe_cast\")
		var maybe_stored_d: Dictionary[String, int] = bytes_to_var(maybe_stored as PackedByteArray)
		for key: String in maybe_stored_d.keys():
			for i in range(maybe_stored_d[key]):
				CurrentRunState.inventory_handler.hold_item(key)


func _on_save_button_pressed() -> void:
	config.set_value(\"debug\", \"x\", var_to_bytes(CurrentRunState.inventory_handler._held_items))
	config.save(\"user://debug.cfg\")


func _on_clear_button_pressed() -> void:
	config.clear()
	config.save(\"user://debug.cfg\")
"

[sub_resource type="GDScript" id="GDScript_4etjd"]
script/source = "extends FoldableContainer


func _process(_delta: float) -> void:
	($VBoxContainer/Label as Label).text = JSON.stringify(CurrentRunState.inventory_handler._held_items, \"  \")
"

