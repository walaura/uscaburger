[sub_resource type="VisualShaderNodeGlobalExpression" id="VisualShaderNodeGlobalExpression_6upfg"]
size = Vector2(780, 440)
expression = "vec2 rotate(float rotation, vec2 uv) {
	vec2 pivot = vec2(.5,.5);
	float cosa = cos(rotation);
	float sina = sin(rotation);
	uv -= pivot;
	return vec2(
		cosa * uv.x - sina * uv.y,
		cosa * uv.y + sina * uv.x 
	) + pivot;
}

float rand(float n){
	return fract(sin(n) * 43758.5453123);
}"

