[sub_resource type="GDScript" id="GDScript_tdcom"]
script/source = "extends VBoxContainer


func _ready() -> void:
	if visible:
		_grab_focus()
	Helper.on_joypad_shape_changed.connect(func(_s:bool)->void:_grab_focus())
		

func show_and_focus() -> void:
	show()
	_grab_focus()

func _grab_focus() -> void:
	var next_valid_focus := find_next_valid_focus()
	if next_valid_focus:
		next_valid_focus.grab_focus.call_deferred()
"

